{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ArchiveFlow",
  "version": "26.2.33",
  "identifier": "com.archiveflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3210",
    "beforeDevCommand": "node scripts/tauri-dev-server.mjs",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ArchiveFlow - 加密压缩包访问辅助工具",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
